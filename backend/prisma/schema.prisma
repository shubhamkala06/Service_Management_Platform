// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_USER_RESPONSE
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketPurpose {
  SUPPORT
  REQUEST
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  SCRAPPED
}

enum LicenseType {
  PERPETUAL
  SUBSCRIPTION
  TRIAL
}

enum AssetType {
  HARDWARE
  SOFTWARE
  OTHER
}

model User {
  id                Int   @id @default(autoincrement())
  oidcSubject       String   @unique

  email             String   @unique

  firstName         String
  lastName          String
  
  department        String
  dateOfJoining     DateTime
  roleId            Int

  isActive          Boolean  @default(true)
  lastLoginAt       DateTime?

  role Role @relation(fields: [roleId], references: [id])

  supportTeamId Int?
  supportTeam SupportTeam? @relation(fields: [supportTeamId], references: [id])
  

  createdTickets  Ticket[]              @relation("CreatedTickets")
  assignedTickets Ticket[]              @relation("AssignedTickets")
  ticketHistory   TicketStatusHistory[] @relation("StatusChangedBy")

  comments            Comment[]
  uploadedAttachments Attachment[] @relation("UploadedAttachments")

  approvalsGiven Approval[] @relation("Approver")

  assignedAssets       AssetAssignment[] @relation("AssignedAssets")
  assetAssignmentsMade AssetAssignment[] @relation("AssignedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([department])
  @@map("users")
  @@index([supportTeamId])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}



model SupportTeam {

  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)

  users       User[]
  categories  SupportCategory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_teams")
}

model SupportCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)
  supportTeamId Int

  supportTeam SupportTeam @relation(fields:[supportTeamId], references:[id])

  tickets   Ticket[]
  SlaPolicy SlaPolicy?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_categories")
}

model SlaPolicy {
  id                Int     @id @default(autoincrement())
  policyName        String
  responseTarget    Int
  resolutionTarget  Int
  isActive          Boolean @default(true)
  supportCategoryId Int     @unique

  supportCategory SupportCategory @relation(fields: [supportCategoryId], references: [id])

  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supportCategoryId])
  @@map("sla_policies")
}

model Ticket {
  id           Int            @id @default(autoincrement())
  ticketNumber String         @unique
  title        String
  description  String
  purpose      TicketPurpose
  priority     TicketPriority
  status       TicketStatus   @default(OPEN)
  createdById  Int
  assignedToId Int?
  categoryId   Int
  slaPolicyId  Int?
  deadline     DateTime?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy  User            @relation("CreatedTickets", fields: [createdById], references: [id])
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  category   SupportCategory @relation(fields: [categoryId], references: [id])
  slaPolicy  SlaPolicy?      @relation(fields: [slaPolicyId], references: [id])

  comments      Comment[]
  approval      Approval?
  statusHistory TicketStatusHistory[]

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
  @@index([categoryId])
  @@index([slaPolicyId])
  @@map("tickets")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdOn DateTime @default(now())
  ticketId  Int
  userId    Int

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  attachments Attachment[]

  @@index([ticketId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id           Int      @id @default(autoincrement())
  fileName     String
  filePath     String
  fileType     String
  fileSize     Int
  uploadedOn   DateTime @default(now())
  commentId    Int
  uploadedById Int

  comment    Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("UploadedAttachments", fields: [uploadedById], references: [id])

  @@index([commentId])
  @@index([uploadedById])
  @@map("attachments")
}

model Approval {
  id         Int              @id @default(autoincrement())
  decision   ApprovalDecision
  remarks    String?
  approvedOn DateTime         @default(now())
  approverId Int
  ticketId   Int              @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approver User   @relation("Approver", fields: [approverId], references: [id])
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([approverId])
  @@map("approvals")
}

model TicketStatusHistory {
  id          Int          @id @default(autoincrement())
  oldStatus   TicketStatus
  newStatus   TicketStatus
  remarks     String?
  changedOn   DateTime     @default(now())
  ticketId    Int
  changedById Int

  updatedAt DateTime @updatedAt

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedById])
  @@map("ticket_status_history")
}

model Asset {
  id             Int         @id @default(autoincrement())
  assetTag       String      @unique
  assetType      AssetType
  assetStatus    AssetStatus @default(AVAILABLE)
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  vendor         String?
  location       String?
  isActive       Boolean     @default(true)

  hardware    Hardware?
  software    Software?
  other       Other?
  assignments AssetAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetStatus])
  @@index([assetType])
  @@map("assets")
}

model Hardware {
  id           Int            @id @default(autoincrement())
  serialNumber String         @unique
  manufacturer String
  model        String
  condition    AssetCondition
  assetId      Int            @unique

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hardware_assets")
}

model Software {
  id           Int         @id @default(autoincrement())
  softwareName String
  version      String
  vendor       String
  licenseKey   String?
  licenseType  LicenseType
  expiryDate   DateTime?
  assetId      Int         @unique

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("software_assets")
}

model Other {
  id          Int     @id @default(autoincrement())
  itemName    String
  description String?
  assetId     Int     @unique

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("other_assets")
}

model AssetAssignment {
  id           Int       @id @default(autoincrement())
  assignedDate DateTime  @default(now())
  returnDate   DateTime?
  remarks      String?
  assetId      Int
  userId       Int
  assignedById Int

  asset      Asset @relation(fields: [assetId], references: [id])
  user       User  @relation("AssignedAssets", fields: [userId], references: [id])
  assignedBy User  @relation("AssignedBy", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([userId])
  @@index([assignedById])
  @@map("asset_assignments")
}

model AuditLog {
  id               Int     @id @default(autoincrement())
  actorType        String
  actorIdentifier  String
  action           String
  targetType       String
  targetIdentifier String
  details          String?
  ipAddress        String?

  createdAt DateTime @default(now())

  @@index([actorIdentifier])
  @@index([targetIdentifier])
  @@index([createdAt])
  @@map("audit_logs")
}
